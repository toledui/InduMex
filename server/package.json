{
  "name": "indumex-server",
  "version": "1.0.0",
  "description": "InduMex 2.0 backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "sequelize-cli db:migrate --config config/config.cjs",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config config/config.cjs",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all --config config/config.cjs",
    "db:create": "sequelize-cli db:create --config config/config.cjs",
    "db:seed": "sequelize-cli db:seed:all --config config/config.cjs",
    "db:seed:undo": "sequelize-cli db:seed:undo:all --config config/config.cjs"
  },
  "type": "commonjs",
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "sequelize-cli": "^6.6.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
